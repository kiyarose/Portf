    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "lychee": "^0.2.12",
    "postcss": "^8.5.16",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
