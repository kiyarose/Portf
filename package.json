    "data:to-ts": "node src/tools/data-converter.mjs to-ts",
    "data:publish": "node scripts/publish-r2-data.mjs",
    "data:sync:remote": "node scripts/sync-remote-data.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@iconify/json": "^2.2.493",
    "@iconify/react": "^6.0.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "pg": "^8.22.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0",
    "tmp": "^0.2.7",
    "wrangler": "^4.103.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
